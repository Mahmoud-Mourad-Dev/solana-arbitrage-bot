# ── Yellowstone Geyser gRPC (Triton One / self-hosted) ──────────────────────
GEYSER_ENDPOINT=https://your-geyser-endpoint.rpcpool.com:443
GEYSER_X_TOKEN=your-x-token

# Standard JSON-RPC endpoint, only used once at bootstrap to hydrate pool
# registry (vault addresses, mints, decimals). Any decent RPC works.
RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
REDIS_OPPORTUNITY_CHANNEL=arbitrage_opportunities
REDIS_OPPORTUNITY_LIST=arbitrage_opportunities
REDIS_OPPORTUNITY_LIST_MAX=1000
# Pool-state pipeline flush cadence (ms) and max buffered commands per flush
REDIS_FLUSH_INTERVAL_MS=20
REDIS_FLUSH_MAX_COMMANDS=256

# ── Discovery engine ─────────────────────────────────────────────────────────
# Cycle base tokens (comma separated mints). Cycles start and end here.
# WSOL ONLY for now: executor tips in lamports and skips non-WSOL bases.
# Add USDC back only after the executor supports USDC-base cost conversion.
BASE_MINTS=So11111111111111111111111111111111111111112
MAX_HOPS=4
# Minimum net profit (after fees + gas + Jito tip) in bps of input to publish
MIN_PROFIT_BPS=10
# Per-hop slippage tolerance baked into published minAmountOut
SLIPPAGE_BPS=20
# Reject Whirlpool quotes whose single-tick approximation moves sqrtPrice
# more than this (tick-crossing risk) — conservative discovery guard.
MAX_CLMM_IMPACT_BPS=100

# ── Trade sizing (input amount optimizer bounds, raw units) ─────────────────
# WSOL: lamports (0.05 SOL .. 10 SOL)
TRADE_MIN_WSOL=50000000
TRADE_MAX_WSOL=10000000000
# USDC: 6 decimals (5 USDC .. 1500 USDC)
TRADE_MIN_USDC=5000000
TRADE_MAX_USDC=1500000000

# ── Execution cost model (lamports) ─────────────────────────────────────────
BASE_SIGNATURE_FEE_LAMPORTS=5000
PRIORITY_FEE_LAMPORTS=100000
JITO_TIP_LAMPORTS=1000000

# ── Publish throttling ───────────────────────────────────────────────────────
# Same cycle is not re-published within this window unless profit improved >5%
OPPORTUNITY_COOLDOWN_MS=500

LOG_LEVEL=info

# ═══════════════ Rust Execution Layer (executor/) ═══════════════
# Path to the payer/authority keypair (json array format)
KEYPAIR_PATH=/path/to/keypair.json
# Deployed address of program/ (solana program deploy target/deploy/arbitrage_program.so)
ARB_PROGRAM_ID=
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles

# Dynamic tip engine: tip = clamp(min, gross_profit * tier_pct, max)
MIN_TIP_LAMPORTS=10000
MAX_TIP_LAMPORTS=100000000

# Compute budget for the bundle transaction
CU_LIMIT=700000
CU_PRICE_MICROLAMPORTS=10000
# Extra on-chain profit demanded beyond tip+fees (lamports)
PROFIT_MARGIN_LAMPORTS=10000

# Opportunity handling
MAX_OPPORTUNITY_AGE_MS=750
MAX_INFLIGHT=4
RESUBMIT_COOLDOWN_MS=400
WHIRLPOOL_TTL_SECS=10

# Address lookup tables (comma separated). Create with:
#   cargo run -p arb-executor --bin create-alt pools.json
LOOKUP_TABLES=

# ── Submission safety (ALL must be flipped for live bundles) ──────────
# Default posture is simulation-only. A real submit requires explicitly:
#   DRY_RUN=false AND ENABLE_SUBMIT=true AND ENABLE_JITO=true
DRY_RUN=true
ENABLE_SUBMIT=false
ENABLE_JITO=false
# Reject opportunities whose projected net (gross - tip - fees - margin)
# is below this many lamports
MIN_NET_PROFIT_LAMPORTS=100000

# ═══════════════ Fused bot (arb-bot) ═══════════════
# arb-bot runs the monitor + executor in ONE process, connected by an
# in-process channel — Redis is NOT on the hot path. Reads all the vars
# above (monitor + executor) plus:
# Bounded in-process opportunity channel capacity (drops under backpressure)
INTERNAL_CHANNEL_CAP=256
# Also publish opportunities to Redis for external observability (off hot path)
MONITOR_REDIS_MIRROR=false

# ═══════════════ Dry-run preview (arb-preview, no Geyser) ═══════════════
# RPC polling interval for `cargo run -p arb-monitor --bin preview`.
# Public RPCs rate-limit; raise this if you see poll failures.
POLL_INTERVAL_MS=3000

# ── Long-run preview (multi-hour dry runs) ──────────────────────────
# Auto-stop after N seconds (0 = run until Ctrl-C). e.g. 21600 = 6 hours.
PREVIEW_DURATION_SECS=0
PREVIEW_POLL_INTERVAL_MS=3000
PREVIEW_MIN_PROFIT_BPS=1
PREVIEW_MAX_POOLS=0
# Re-fetch tick arrays every N seconds so exact quotes stay valid as price drifts.
PREVIEW_TICK_REFRESH_SECS=300
PREVIEW_REPORT_FILE=preview-report.json
# For multi-hour runs use a PRIVATE RPC (Helius/Triton/QuickNode free tier);
# the public api.mainnet-beta endpoint will rate-limit across hours.
